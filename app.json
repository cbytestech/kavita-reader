{
  "expo": {
    "name": "KavitaReader",
    "slug": "kavita-reader",
    "description": "A modern mobile reader for Kavita servers",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D4A2C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hesshomestead.reader",
      "buildNumber": "1.0.1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D4A2C"
      },
      "package": "com.hesshomestead.reader",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "versionCode": 9
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "githubUrl": "https://github.com/cbytestech/kavita-reader",
    "extra": {
      "eas": {
        "projectId": "45df5044-5be7-4201-8f7b-760737b9f86d"
      }
    },
    "owner": "webtechnick",
    "plugins": [
      "expo-audio"
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/45df5044-5be7-4201-8f7b-760737b9f86d"
    }
  }
}